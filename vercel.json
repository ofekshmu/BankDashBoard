{
  "buildCommand": "pip install -r requirements.txt",
  "outputDirectory": ".",
  "env": {
    "ADMIN_PASSWORD": "@admin_password",
    "DATABASE_URL": "@database_url",
    "FLASK_SECRET_KEY": "@flask_secret_key"
  },
  "functions": {
    "source/AppManager.py": {
      "memory": 1024,
      "timeout": 60
    }
  }
}
