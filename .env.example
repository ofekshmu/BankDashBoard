# Copy this file to .env and fill in your Supabase / Neon / any PostgreSQL connection string.
# The .env file is gitignored and must NEVER be committed.
#
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Supabase example: postgresql://postgres:your-password@db.xxxxxxxxxxxx.supabase.co:5432/postgres
# Neon example:     postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
#
DATABASE_URL=postgresql://user:password@host:5432/dbname
